{
  "crons": [
    {
      "path": "/api/cron/every-minute",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/every-five-minutes",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/webhooks/google/renew",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/verify-social-posts",
